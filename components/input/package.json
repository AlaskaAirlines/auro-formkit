{
  "name": "@aurodesignsystem/auro-input",
  "version": "4.2.0",
  "description": "auro-input HTML custom element",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlaskaAirlines/auro-input"
  },
  "dependencies": {
    "@aurodesignsystem/auro-helptext": "*",
    "@aurodesignsystem/auro-icon": "^9.1.1",
    "@aurodesignsystem/auro-layout-element": "*",
    "chalk": "^5.4.1",
    "date-fns": "^4.1.0",
    "imask": "^7.6.1"
  },
  "devDependencies": {
    "@alaskaairux/icons": "^5.14.0",
    "@aurodesignsystem/build-tools": "*",
    "@aurodesignsystem/config": "*",
    "@aurodesignsystem/form-validation": "*",
    "@aurodesignsystem/typescript": "*",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "backstopjs": "^6.3.25",
    "rollup": "^4.40.1",
    "rollup-plugin-serve": "^3.0.0",
    "sinon": "^20.0.0",
    "wc-sass-render": "^1.4.0",
    "web-component-analyzer": "^2.0.0"
  },
  "overrides": {
    "wc-sass-render": {
      "sass": "$sass"
    }
  },
  "nodemonConfig": {
    "ext": "scss,js,md",
    "watch": ["src", "docs", "demo", "apiExamples"],
    "ignore": [
      "*-css.js",
      "*.css",
      "*.min.css",
      "*.min.js",
      "docs/api.md",
      "demo/*.md"
    ],
    "exec": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "run-s sass bundler types build:docs",
    "sass": "run-s build:sass postCss:component sass:render",
    "build:version": "node ./scripts/version.mjs",
    "build:sass": "sass --no-source-map --quiet-deps --load-path=../../node_modules \"./src/styles/:./src/styles/\"",
    "build:watch": "nodemon",
    "bundler": "rollup -c node:@aurodesignsystem/config/rollup",
    "build:docs": "wca analyze 'scripts/wca/*.js' --outFiles docs/api.md; npm run docs; node ../../packages/build-tools/src/generatePageManifest.mjs",
    "clean": "rm -rf dist build",
    "dev": "concurrently \"npm run build:watch\" \"npm run serve\"",
    "dev:closed": "concurrently \"npm run build:watch\" \"npm run serve:closed\"",
    "serve": "npm run docs -- -s -w --open",
    "serve:closed": "npm run docs -- -s -w",
    "docs": "auro docs -r '../../docs/templates/componentReadmeTemplate.md' -p 8803",
    "postCss:component": "node ../../node_modules/@aurodesignsystem/auro-library/scripts/build/postCss.mjs",
    "sass:render": "sass-render -i ../../node_modules --suffix=-css.js 'src/**/*.css' -t ../../node_modules/@aurodesignsystem/auro-library/scripts/build/staticStyles-template.js",
    "test": "wtr --config \"../../packages/config/src/web-test-runner.config.mjs\" --coverage --port 7703",
    "test:watch": "wtr --config \"../../packages/config/src/web-test-runner.config.mjs\" --watch --port 7703",
    "types": "tsc --project tsconfig.json",
    "lint": "npm-run-all scssLint esLint",
    "scssLint": "stylelint \"./src/**/*.scss\"",
    "esLint": "eslint \"./src/**/*.js\""
  }
}
