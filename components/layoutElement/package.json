{
  "name": "@aurodesignsystem/auro-layout-element",
  "version": "1.0.0",
  "description": "auro-element-layout HTML custom element",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "private": true,
  "nodemonConfig": {
    "ext": "scss,js,md",
    "watch": ["src", "docs", "demo", "apiExamples"],
    "ignore": [
      "*-css.js",
      "*.css",
      "*.min.css",
      "*.min.js",
      "docs/api.md",
      "demo/*.md"
    ],
    "exec": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "run-s types bundler",
    "build:watch": "nodemon",
    "bundler": "rollup -c node:@aurodesignsystem/config/internal.rollup",
    "clean": "rm -rf dist build",
    "test": "wtr --config \"web-test-runner.config.mjs\" --coverage --port 7713",
    "test:watch": "wtr --config \"web-test-runner.config.mjs\" --watch --port 7713",
    "types": "tsc --project tsconfig.json",
    "lint": "npm-run-all esLint",
    "esLint": "eslint \"./src/**/*.js\""
  }
}
