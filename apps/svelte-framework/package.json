{
	"name": "@aurodesignsystem/svelte-framework",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:app": "vite dev",
		"dev:app:open": "npm run dev:app -- --open",
		"build:app": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"clean:cache": "rm -rf .svelte-kit node_modules/.vite",
		"pretest:framework": "npm run clean:cache && npx playwright install chromium",
		"test:framework": "playwright test"
	},
	"dependencies": {
		"@aurodesignsystem/auro-formkit": "file:../../"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
